<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Deep-space radial gradient: dark navy at centre bleeding out to near-black purple.
        gradientRadius 76 ≈ 54√2, which covers the full 108×108 canvas to its corners.
    -->
    <path android:pathData="M0,0h108v108H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76">
                <item android:offset="0.00" android:color="#1E2E60"/>
                <item android:offset="0.50" android:color="#110D38"/>
                <item android:offset="1.00" android:color="#050310"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>
